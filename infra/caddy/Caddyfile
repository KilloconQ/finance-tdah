# Caddy reverse proxy interno. TLS lo termina Cloudflare Tunnel.
{
	admin off
	auto_https off
	servers {
		trusted_proxies static private_ranges
	}
}

:80 {
	encode zstd gzip

	# Health probe (no logueado)
	@health path /health
	respond @health "ok" 200

	# API → Hono/Bun
	handle /api/* {
		reverse_proxy api:3001 {
			header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
			header_up X-Forwarded-Host {http.request.host}
		}
	}

	# Auth endpoints (Better-Auth) bajo /api/auth/*
	handle /api/auth/* {
		reverse_proxy api:3001
	}

	# SPA estática servida por nginx en el contenedor web
	handle {
		reverse_proxy web:80
	}

	log {
		output stdout
		format console
		level INFO
	}
}
