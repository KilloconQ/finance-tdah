{
  "name": "@finance-tdah/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --target=bun --outfile=dist/server.js",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/db/seed.ts",
    "auth:schema": "bunx @better-auth/cli generate --config ./src/auth.ts --output ./src/db/auth-generated.ts"
  },
  "dependencies": {
    "@finance-tdah/shared": "workspace:*",
    "@hono/zod-validator": "^0.4.3",
    "better-auth": "^1.2.10",
    "drizzle-orm": "^0.39.0",
    "hono": "^4.9.0",
    "pg": "^8.13.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.7"
  }
}
